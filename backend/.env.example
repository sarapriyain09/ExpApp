# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Port to listen on
PORT=3001

# Set this to your frontend's origin to restrict CORS (recommended in production)
# e.g. ALLOWED_ORIGIN=https://yourapp.example.com
# Use * to allow all origins (only for local/trusted networks)
ALLOWED_ORIGIN=*
